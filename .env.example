# Preferred explicit names (take precedence when both are set)
ALEPH_BASE_URL=https://your-openaleph.example.org
ALEPH_API_KEY=your_api_key_here

# OpenAleph Python/CLI convention (used if ALEPH_* vars are unset)
# OPAL_HOST=https://your-openaleph.example.org
# OPAL_API_KEY=your_api_key_here

# Optional: HTTP timeout in ms (default 60000, clamped 1000–600000)
# ALEPH_REQUEST_TIMEOUT_MS=60000

# Optional: stable value for X-Aleph-Session header (default: random UUID per process)
# ALEPH_SESSION_ID=

# --- E2E search (`npm run test:e2e`) — tune the OpenAleph query without editing test code
# ALEPH_E2E_SEARCH_Q=test
# ALEPH_E2E_SEARCH_LIMIT=5
# ALEPH_E2E_SEARCH_OFFSET=0
# ALEPH_E2E_SEARCH_COLLECTION_ID=
# Page = per-page shards (bodyText on each Page); Pages = whole-file entity. Pick the schema your query targets.
# ALEPH_E2E_SEARCH_SCHEMA=Email
# ALEPH_E2E_SEARCH_SCHEMATA=
# ALEPH_E2E_SEARCH_FACETS=languages,countries
# ALEPH_E2E_SEARCH_EXTRA_FILTERS={"mime_type":"application/pdf"}
# Request ES highlights on search (default on). Set to false to omit highlight=true from the URL.
# ALEPH_E2E_SEARCH_HIGHLIGHT=false
# ALEPH_E2E_SEARCH_HIGHLIGHT_COUNT=15
# After search, GET /api/2/entities/:id for the first N hits (default 2, max 50)
# ALEPH_E2E_FETCH_TOP_N=2
