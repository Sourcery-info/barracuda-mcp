# Preferred explicit names (take precedence when both are set)
ALEPH_BASE_URL=https://your-openaleph.example.org
ALEPH_API_KEY=your_api_key_here

# OpenAleph Python/CLI convention (used if ALEPH_* vars are unset)
# OPAL_HOST=https://your-openaleph.example.org
# OPAL_API_KEY=your_api_key_here

# Optional: HTTP timeout in ms (default 60000, clamped 1000–600000)
# ALEPH_REQUEST_TIMEOUT_MS=60000

# Optional: stable value for X-Aleph-Session header (default: random UUID per process)
# ALEPH_SESSION_ID=

# --- E2E search (`npm run test:e2e`) — tune the OpenAleph query without editing test code
# ALEPH_E2E_SEARCH_Q=test
# ALEPH_E2E_SEARCH_LIMIT=5
# ALEPH_E2E_SEARCH_OFFSET=0
# ALEPH_E2E_SEARCH_COLLECTION_ID=
# Page = per-page shards (bodyText on each Page); Pages = whole-file entity. Pick the schema your query targets.
# ALEPH_E2E_SEARCH_SCHEMA=Email
# ALEPH_E2E_SEARCH_SCHEMATA=
# ALEPH_E2E_SEARCH_FACETS=languages,countries
# ALEPH_E2E_SEARCH_EXTRA_FILTERS={"mime_type":"application/pdf"}
# Request ES highlights on search (default on). Set to false to omit highlight=true from the URL.
# ALEPH_E2E_SEARCH_HIGHLIGHT=false
# ALEPH_E2E_SEARCH_HIGHLIGHT_COUNT=15
# ALEPH_E2E_SEARCH_HIGHLIGHT_LENGTH=200

# --- E2E search tool shaping (applied to runAlephSearchTool in the e2e run)
# responseMode: structured (default) returns a slim JSON array of hits; raw returns unmodified Aleph JSON.
# ALEPH_E2E_SEARCH_RESPONSE_MODE=structured
# Include the raw Aleph response alongside structured output ({ "results", "raw" }).
# ALEPH_E2E_SEARCH_INCLUDE_RAW=false
# Keep heavy text fields (bodyHtml / bodyText / translatedText) in structured output.
# ALEPH_E2E_SEARCH_INCLUDE_CONTENT_FIELDS=true
# Cap Email bodyMarkdown (HTML→Markdown) and Page/Pages bodyText length. 0 disables this override.
# ALEPH_E2E_SEARCH_CONTENT_PREVIEW_CHARS=500
# When contentPreviewChars is 0, max length for Email bodyMarkdown / Page bodyText (search default 200).
# ALEPH_E2E_SEARCH_BODY_MARKDOWN_MAX_CHARS=1000
# Cap list length per property field in structured output (default 20, max 200).
# ALEPH_E2E_SEARCH_MAX_ARRAY_VALUES_PER_FIELD=20

# After search, GET /api/2/entities/:id for the first N hits (default 2, max 50)
# ALEPH_E2E_FETCH_TOP_N=2

# --- Targeted single-entity e2e (`npm run test:e2e:entity` or `npm run e2e:entity`)
# The targeted entity test is skipped unless ALEPH_E2E_ENTITY_ID is set.
# The CLI script accepts the id as a positional arg (npm run e2e:entity -- <id>) which overrides this.
# ALEPH_E2E_ENTITY_ID=
# Follow up aleph_get_entity with aleph_get_entity_markdown (default true).
# ALEPH_E2E_ENTITY_FETCH_MARKDOWN=true
# Structured-response shaping for aleph_get_entity (same semantics as the search shaping above).
# ALEPH_E2E_ENTITY_RESPONSE_MODE=structured
# ALEPH_E2E_ENTITY_INCLUDE_RAW=false
# ALEPH_E2E_ENTITY_INCLUDE_CONTENT_FIELDS=true
# ALEPH_E2E_ENTITY_CONTENT_PREVIEW_CHARS=500
# ALEPH_E2E_ENTITY_BODY_MARKDOWN_MAX_CHARS=6000
# ALEPH_E2E_ENTITY_MAX_ARRAY_VALUES_PER_FIELD=20
