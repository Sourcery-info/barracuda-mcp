{
  "name": "barracuda-mcp",
  "version": "0.1.0",
  "description": "MCP server for OpenAleph entity search",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "barracuda-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "openaleph",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "turndown": "^7.2.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.15.0",
    "@types/turndown": "^5.0.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.1.0"
  }
}
