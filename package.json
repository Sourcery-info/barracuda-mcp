{
  "name": "barracuda-mcp",
  "version": "0.1.0",
  "description": "MCP server for OpenAleph entity and document search.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "barracuda-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:entity": "vitest run --config vitest.e2e.config.ts test/e2e/aleph-entity.e2e.test.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "e2e:entity": "tsx scripts/fetch-entity.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openaleph",
    "aleph",
    "opal",
    "cursor",
    "followthemoney",
    "entity-search"
  ],
  "author": "Jason Norwood-Young <jason@10layer.com>",
  "license": "MIT",
  "homepage": "https://github.com/Sourcery-info/barracuda-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sourcery-info/barracuda-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Sourcery-info/barracuda-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "turndown": "^7.2.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.15.0",
    "@types/turndown": "^5.0.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.1.0"
  }
}
